{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dola 文档",
  "colors": {
    "primary": "#BEA780",
    "light": "#DDC99C",
    "dark": "#9D8263"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "fonts": {
    "heading": {
      "family": "Poppins",
      "source": "/fonts/Poppins-700.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "Open Sans",
      "source": "/fonts/Open_Sans-400.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "当前文档",
        "groups": [
          {
            "group": "开始使用",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "introduction",
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "使用 Agent",
            "icon": "robot",
            "expanded": true,
            "pages": [
              "agents/overview",
              "agents/membership",
              "agents/ai-payments",
              "agents/models"
            ]
          },
          {
            "group": "Agent 商店",
            "icon": "store",
            "expanded": true,
            "pages": [
              "marketplace/overview",
              "marketplace/referrals",
              "marketplace/resellers"
            ]
          },
          {
            "group": "账号与设置",
            "icon": "gear",
            "expanded": true,
            "pages": [
              "account/setup",
              "account/settings",
              "account/faq"
            ]
          }
        ]
      },
      {
        "tab": "旧版文档",
        "groups": [
          {
            "group": "开始使用",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "old/index",
              "old/introduction",
              "old/quickstart",
              "old/core-concepts"
            ]
          },
          {
            "group": "使用 Agent",
            "icon": "robot",
            "expanded": true,
            "pages": [
              "old/agents/overview",
              "old/agents/building",
              "old/agents/models",
              "old/agents/skills"
            ]
          },
          {
            "group": "Agent 商店",
            "icon": "store",
            "expanded": true,
            "pages": [
              "old/marketplace/overview",
              "old/marketplace/selling",
              "old/marketplace/buying",
              "old/marketplace/referrals"
            ]
          },
          {
            "group": "支付与结算",
            "icon": "credit-card",
            "expanded": true,
            "pages": [
              "old/payments/overview",
              "old/payments/pricing",
              "old/payments/settlements"
            ]
          },
          {
            "group": "账号与设置",
            "icon": "gear",
            "expanded": true,
            "pages": [
              "old/account/setup",
              "old/account/settings",
              "old/account/faq"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "支持",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "控制台",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
