  "colors": {
    "primary": "#ccbc8c",
    "light": "#b79f7a",
    "dark": "#ffffff"
  },
  "favicon": "https://media.brand.dev/a19480f5-219e-4168-88cc-2407395dba68.png",
  "logo": {
    "light": "https://media.brand.dev/e2196fe9-d7c7-423e-ba2a-a516a093d6c6.svg",
    "dark": "https://media.brand.dev/e2196fe9-d7c7-423e-ba2a-a516a093d6c6.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
