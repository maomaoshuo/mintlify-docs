  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Marketplace",
          "icon": "store",
          "href": "https://www.dolaio.cn"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "https://www.dolaio.cn"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get Started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "introduction",
          "quickstart",
          "core-concepts"
        ]
      },
      {
        "group": "Creating Agents",
        "icon": "bot",
        "expanded": true,
        "pages": [
          "agents/overview",
          "agents/building",
          "agents/models",
          "agents/skills"
        ]
      },
      {
        "group": "Marketplace",
        "icon": "store",
        "expanded": true,
        "pages": [
          "marketplace/overview",
          "marketplace/selling",
          "marketplace/buying",
          "marketplace/referrals"
        ]
      },
      {
        "group": "Payments & Billing",
        "icon": "credit-card",
        "expanded": true,
        "pages": [
          "payments/overview",
          "payments/pricing",
          "payments/settlements"
        ]
      },
      {
        "group": "Account & Settings",
        "icon": "settings",
        "expanded": true,
        "pages": [
          "account/setup",
          "account/settings",
          "account/faq"
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Go to Dola",
      "href": "https://www.dolaio.cn"
    }
